# Copy this file to `.env` and adjust values for your environment.
# All variables are optional — sensible defaults are used when unset.

# --- Backend ------------------------------------------------------------

# Allowed CORS origins for the FastAPI server.
# Comma-separated list, no spaces around commas.
# When unset, defaults to: http://localhost:5173, http://127.0.0.1:5173, http://localhost:3000
# Set this to your production frontend origin(s) before deploying.
# CORS_ORIGINS=https://myapp.example.com,https://staging.myapp.example.com

# yt-dlp authentication for private / age-gated YouTube videos.
# Pick ONE of the two: browser-cookies OR a cookies.txt file.
# YTDLP_COOKIES_FROM_BROWSER=chrome
# YTDLP_COOKIES=/absolute/path/to/cookies.txt

# Override the Grounding-Dino / OWLv2 model used for open-vocabulary verify.
# OWL_MODEL_ID=google/owlv2-base-patch16-ensemble

# --- Frontend (Vite) ----------------------------------------------------
# Vite only exposes variables prefixed with VITE_ to the client bundle.

# Base URL the React app hits for API calls. Defaults to http://localhost:8000.
# VITE_API_URL=http://localhost:8000
